      "name": "🔐 AUTHENTICATION",
      "item": [
        {
          "name": "Doctor Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Sarah Johnson\",\n  \"email\": \"dr.sarah@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"role\": \"DOCTOR\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/signup",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "signup"]
            }
          }
        },
